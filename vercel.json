{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/api/unit-jobs/:id/cancel", "destination": "/api/unit-job-cancel?id=:id" },
    { "source": "/api/unit-jobs/:id/retry", "destination": "/api/unit-job-retry?id=:id" },
    { "source": "/api/unit-jobs/:id", "destination": "/api/unit-job?id=:id" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
