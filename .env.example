# Copy to .env.local for local development, and add the same keys in
# Vercel → Project → Settings → Environment Variables for deployment.
# .env.local is git-ignored. NONE of these are exposed to the browser.

# Required: powers Ask + unit generation (server-side only).
ANTHROPIC_API_KEY=

# Required in production: durable unit-generation job store.
# SUPABASE_URL is safe to be public; SUPABASE_SERVICE_ROLE_KEY must stay
# server-only (it bypasses RLS) — never put it in frontend code.
# If both are omitted locally, jobs fall back to a local SQLite store.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: set to "production" to suppress verbose error detail.
FINLINGO_ENV=
